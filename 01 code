class DVD {
    private String title;
    private String category;
    private String director;
    private int length;
    private float cost;

    public DVD(String title, String category, String director, int length, float cost) {
        this.title = title;
        this.category = category;
        this.director = director;
        this.length = length;
        this.cost = cost;
    }

    public String getTitle() { return title; }
    public String getCategory() { return category; }
    public String getDirector() { return director; }
    public int getLength() { return length; }
    public float getCost() { return cost; }
}

class Cart {
    public static final int MAX_NUMBERS_ORDERED = 20;
    private DVD itemsList[] = new DVD[MAX_NUMBERS_ORDERED];
    private int qtyOrdered = 0;

    public void addDVD(DVD disc) {
        if (qtyOrdered < MAX_NUMBERS_ORDERED) {
            itemsList[qtyOrdered] = disc;
            qtyOrdered++;
            System.out.println("Đã thêm đĩa: " + disc.getTitle());
        } else {
            System.out.println("Giỏ hàng đã đầy, không thể thêm đĩa mới!");
        }
    }

    public void removeDVD(DVD disc) {
        for (int i = 0; i < qtyOrdered; i++) {
            if (itemsList[i] == disc) {
                for (int j = i; j < qtyOrdered - 1; j++) {
                    itemsList[j] = itemsList[j + 1];
                }
                itemsList[qtyOrdered - 1] = null;
                qtyOrdered--;
                System.out.println("Đã xóa đĩa: " + disc.getTitle());
                return;
            }
        }
        System.out.println("Không tìm thấy đĩa này trong giỏ hàng.");
    }

    public float totalCost() {
        float total = 0;
        for (int i = 0; i < qtyOrdered; i++) {
            total += itemsList[i].getCost();
        }
        return total;
    }
}

public class Aims {
    public static void main(String[] args) {
        Cart anOrder = new Cart();

        DVD dvd1 = new DVD("The Lion King", "Animation", "Roger Allers", 87, 19.95f);
        anOrder.addDVD(dvd1);

        DVD dvd2 = new DVD("Star Wars", "Science Fiction", "George Lucas", 124, 24.95f);
        anOrder.addDVD(dvd2);

        DVD dvd3 = new DVD("Aladdin", "Animation", "John Musker", 90, 18.99f);
        anOrder.addDVD(dvd3);

        System.out.println("Tổng chi phí là: " + anOrder.totalCost());

        anOrder.removeDVD(dvd2);
        System.out.println("Tổng chi phí sau khi xóa Star Wars là: " + anOrder.totalCost());
    }
}
